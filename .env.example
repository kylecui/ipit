# ─── 威胁情报 API 密钥（可选，不配置则对应收集器跳过） ─────
ABUSEIPDB_API_KEY=
OTX_API_KEY=
GREYNOISE_API_KEY=
VT_API_KEY=
SHODAN_API_KEY=

# ─── 性能设置 ─────────────────────────────────────────────────
CACHE_TTL_HOURS=24
HTTP_TIMEOUT_SECONDS=15
MAX_RETRIES=2
LOG_LEVEL=INFO

# ─── 语言设置 ─────────────────────────────────────────────────
# 默认界面语言：en（英文）或 zh（中文）
LANGUAGE=en

# ─── LLM 设置（可选，用于生成详细分析报告） ──────────────────
# 支持 OpenAI 兼容接口（OpenAI / Azure / Ollama 等）
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# ─── 部署设置（docker-compose 使用） ─────────────────────────
# 反向代理路径前缀（部署在子路径时设置，如 /v2）
ROOT_PATH=
