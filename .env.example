# ─── 威胁情报 API 密钥（可选，不配置则对应收集器跳过） ─────
ABUSEIPDB_API_KEY=
OTX_API_KEY=
GREYNOISE_API_KEY=
VT_API_KEY=
SHODAN_API_KEY=

# ─── 性能设置 ─────────────────────────────────────────────────
CACHE_TTL_HOURS=24
HTTP_TIMEOUT_SECONDS=15
MAX_RETRIES=2
LOG_LEVEL=INFO

# ─── 语言设置 ─────────────────────────────────────────────────
# 默认界面语言：en（英文）或 zh（中文）
LANGUAGE=en

# ─── 部署设置（docker-compose 使用） ─────────────────────────
# Nginx 对外暴露的端口（默认 80）
TIRE_PORT=80
