# ─── 威胁情报 API 密钥（可选，不配置则对应收集器跳过） ─────
ABUSEIPDB_API_KEY=
OTX_API_KEY=
GREYNOISE_API_KEY=
VT_API_KEY=
SHODAN_API_KEY=
THREATBOOK_API_KEY=
TIANJIYOUMENG_API_KEY=

# ─── 性能设置 ─────────────────────────────────────────────────
CACHE_TTL_HOURS=24
HTTP_TIMEOUT_SECONDS=15
MAX_RETRIES=2
LOG_LEVEL=INFO

# ─── 语言设置 ─────────────────────────────────────────────────
# 默认界面语言：en（英文）或 zh（中文）
LANGUAGE=en

# ─── LLM 设置（可选，用于生成详细分析报告） ──────────────────
# 支持 OpenAI 兼容接口（OpenAI / Azure / Ollama 等）
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# ─── 部署设置（docker-compose 使用） ─────────────────────────
# 应用端口（默认 8000）
TIRE_PORT=8000
# 反向代理路径前缀（部署在子路径时设置，如 /v2）
ROOT_PATH=

# ─── 数据持久化设置 ─────────────────────────────────────────────
# Fernet 加密密钥（用于加密存储的 API 密钥）
# 生产环境必须设置！可通过 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成
TIRE_FERNET_KEY=

# 查询结果过期天数（超过此天数的结果将触发重新查询）
RESULT_STALENESS_DAYS=7

# ─── 管理后台设置 ─────────────────────────────────────────────
# Session 加密密钥（生产环境请务必修改）
SESSION_SECRET_KEY=change-me-in-production
# 初始管理员密码（仅在首次启动、无用户时使用）
ADMIN_PASSWORD=admin
