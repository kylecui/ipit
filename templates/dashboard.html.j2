<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Threat Intelligence Reasoning Engine</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-4">
        <div class="row">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h1 class="h4 mb-0">Threat Intelligence Reasoning Engine</h1>
                    </div>
                    <div class="card-body">
                        <p class="lead">Analyze IP addresses for potential security threats using multi-source intelligence.</p>

                        <form method="post" action="/analyze">
                            <div class="mb-3">
                                <label for="ip" class="form-label">IP Address</label>
                                <input type="text" class="form-control" id="ip" name="ip"
                                       value="{{ ip or '' }}" placeholder="Enter IP address (e.g., 192.168.1.1)"
                                       required pattern="^(\d{1,3}\.){3}\d{1,3}$"
                                       title="Please enter a valid IP address">
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="refresh" name="refresh" {% if refresh %}checked{% endif %}>
                                <label class="form-check-label" for="refresh">
                                    Refresh cache (bypass cached results)
                                </label>
                            </div>
                            <button type="submit" class="btn btn-primary">Analyze IP</button>
                        </form>

                        {% if error %}
                        <div class="alert alert-danger mt-4">
                            <strong>Error:</strong> {{ error }}
                        </div>
                        {% endif %}

                        {% if html_report %}
                        <div class="mt-4">
                            {{ html_report | safe }}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>